{
	"name": "server",
	"main": "index.ts",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently 'tsc -w' 'node --watch --env-file=../.env.development dist/index.js'",
		"build": "tsc",
		"quickstart": "node --env-file=../.env.production dist/index.js",
		"start": "npm run build && npm run quickstart"
	},
	"dependencies": {
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"pg": "^8.20.0",
		"pg-hstore": "^2.3.4",
		"sequelize": "^6.37.8"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.6.0",
		"concurrently": "^9.2.1"
	}
}
